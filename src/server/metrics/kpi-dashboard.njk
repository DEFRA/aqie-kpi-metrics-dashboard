{% extends 'layouts/page.njk' %}

{% block pageContent %}
  {# Header section #}
  <div class="dashboard-header govuk-!-margin-bottom-6">
    {{ appHeading({
      text: heading,
      caption: "Monitor your key performance indicators and user engagement metrics",
      classes: "govuk-heading-xl govuk-!-margin-bottom-2"
    }) }}
  </div>

  {# 1. KPI SECTION #}
  <section class="kpi-section" aria-label="Key Performance Indicators">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-half">
        <div class="kpi-card" id="card-completion-rate">
          <h2 class="govuk-heading-s govuk-!-margin-bottom-2" style="color: #0b0c0c;">Completion rate</h2>
          <span class="govuk-heading-xl govuk-!-margin-bottom-1" id="display-completion-rate">0%</span>
          <p class="govuk-body-s govuk-!-margin-0 kpi-card__source" id="source-completion-rate" style="color: #505a5f; display: none;">
            Calculated from <strong id="source-completed">0</strong> completed of <strong id="source-started">0</strong> started
          </p>
          <span class="govuk-body-s kpi-card__date" id="date-completion-rate" style="display: none;"></span>
        </div>
      </div>

      <div class="govuk-grid-column-one-half">
        <div class="kpi-card" id="card-cost-per-transaction">
          <h2 class="govuk-heading-s govuk-!-margin-bottom-2" style="color: #0b0c0c;">Cost per transaction</h2>
          <span class="govuk-heading-xl govuk-!-margin-bottom-1" id="display-cost-per-transaction">&pound;0.00</span>
          <p class="govuk-body-s govuk-!-margin-0 kpi-card__source" id="source-cost-per-transaction" style="color: #505a5f; display: none;">
            Calculated from &pound;<strong id="source-total-run-cost">0</strong> across <strong id="source-total-transactions">0</strong> transactions
          </p>
          <span class="govuk-body-s kpi-card__date" id="date-cost-per-transaction" style="display: none;"></span>
        </div>
      </div>
    </div>
  </section>

  {# 2. CHARTS SECTION #}
  <section class="charts-section govuk-!-margin-top-8">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-half">
        <h3 class="govuk-heading-m">Completion rate trend</h3>
        <div class="chart-container" style="position: relative; height:300px; width:100%">
          <canvas id="chart-completion"></canvas>
        </div>
      </div>

      <div class="govuk-grid-column-one-half">
        <h3 class="govuk-heading-m">Cost per transaction trend</h3>
        <div class="chart-container" style="position: relative; height:300px; width:100%">
          <canvas id="chart-cost"></canvas>
        </div>
      </div>
    </div>
  </section>
{% endblock %}